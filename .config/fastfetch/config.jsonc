{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": {
    "width": 1,
    "type": "file",
    "source": "/home/medhansh/.fastfetch/ascii.txt",
    "color": {
      "1": "#9bd4a2",
      "2": "#b5cdb5",
      "3": "#ffb1c2",
      "4": "#689f71",
      "5": "#374c39",
      "6": "#c97c8e"
    }
  },
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "separator",
    "terminal",
    "terminalfont",
    "separator",
    "cpu",
    "gpu",
    {
      "type": "memory",
      "format": "DDR5 {used}/{total}"
    },
    "separator",
    "localip",
    "battery",
    "poweradapter",
    "separator",
    {
      "key": "OS Age",
      "type": "disk",
      "folders": "/",
      "format": "{create-time:10} ({days} days)"
    },
    "break",
    "colors"
  ]
}
